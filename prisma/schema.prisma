// prisma/schema.prisma
// Exakt Platform — Prisma 6 + PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
}

enum CompanyRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum TenderStatus {
  DRAFT
  SUBMITTED
  WON
  LOST
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CANCELLED
}

enum DeliveryOrderStatus {
  PENDING
  PARTIAL
  DELIVERED
  CANCELLED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ActivityStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

// ─────────────────────────────────────────────────────────────────────────────
// COMPANY — owns the subscription and team seats
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  plan             Plan      @default(FREE)
  seatLimit        Int       @default(1)

  // Stripe billing
  stripeCustomerId String?   @unique
  stripeSubId      String?   @unique
  stripePriceId    String?
  planExpiresAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     CompanyMember[]
  invitations CompanyInvite[]

  // Data owned by this company
  mtoSystems             MtoSystem[]
  mtoJobs                MtoJob[]
  materialSpecs          MaterialSpec[]
  reports                Report[]
  clients                Client[]
  tenders                Tender[]
  materialGrades         MaterialGrade[]
  manufacturers          Manufacturer[]
  libraryItems           LibraryItem[]
  materialCertifications MaterialCertification[]
  suppliers              Supplier[]
  purchaseOrders         PurchaseOrder[]
  deliveryOrders         DeliveryOrder[]
  materialCategories     MaterialCategory[]
  globalTags             GlobalTag[]
  activityLibrary        ActivityLibraryItem[]
  tenderReports          TenderReport[]
  tenderTemplates        Json           @default("[]")
  tenderReportDefaults   Json           @default("{}")
  predefinedItemsLibrary Json           @default("[]")
  labourRates            LabourRate[]
  workCategories         WorkCategory[]
  workActivityRates      WorkActivityRate[]
  tasks                  Task[]
  notifications          Notification[]
  projects               Project[]
  workTeams              WorkTeam[]
  projectAssets          ProjectAsset[]

  @@map("companies")
}

model CompanyMember {
  companyId   String
  userId      String
  role        CompanyRole @default(MEMBER)
  permissions Json        @default("{}")   // { systems: "write", library: "read", reports: "none", ... }
  joinedAt    DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([companyId, userId])
  @@map("company_members")
}

model CompanyInvite {
  id          String      @id @default(cuid())
  companyId   String
  email       String
  role        CompanyRole @default(MEMBER)
  permissions Json        @default("{}")
  token       String      @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, email])
  @@map("company_invites")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER + PROFILE
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id        String   @id  // matches Supabase auth.users.id
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  companyMembers   CompanyMember[]
  profile          Profile?

  // "Created by" audit trail
  createdSystems             MtoSystem[]             @relation("createdByUser")
  createdJobs                MtoJob[]                @relation("createdByUser")
  createdMaterialSpecs       MaterialSpec[]          @relation("createdByUser")
  createdReports             Report[]                @relation("createdByUser")
  createdClients             Client[]                @relation("createdByUser")
  createdTenders             Tender[]                @relation("createdByUser")
  createdMaterialGrades      MaterialGrade[]         @relation("createdByUser")
  createdManufacturers       Manufacturer[]          @relation("createdByUser")
  createdLibraryItems        LibraryItem[]           @relation("createdByUser")
  createdCertifications      MaterialCertification[] @relation("createdByUser")
  createdSuppliers           Supplier[]              @relation("createdByUser")
  createdPurchaseOrders      PurchaseOrder[]         @relation("createdByUser")
  createdDeliveryOrders      DeliveryOrder[]         @relation("createdByUser")
  createdMaterialCategories  MaterialCategory[]      @relation("createdByUser")
  createdGlobalTags          GlobalTag[]             @relation("createdByUser")
  createdActivityLibrary     ActivityLibraryItem[]   @relation("createdByUser")
  createdTenderReports       TenderReport[]          @relation("createdByUser")
  createdLabourRates         LabourRate[]            @relation("createdByUser")
  createdWorkCategories      WorkCategory[]          @relation("createdByUser")
  createdWorkActivityRates   WorkActivityRate[]      @relation("createdByUser")
  tasksCreated               Task[]                  @relation("taskCreatedBy")
  tasksAssigned              Task[]                  @relation("taskAssignee")
  taskComments               TaskComment[]           @relation("taskComments")
  notifications              Notification[]          @relation("notifications")
  projectsCreated            Project[]               @relation("projectCreatedBy")
  projectsManaged            Project[]               @relation("projectManager")
  activitiesAssigned         ProjectActivity[]       @relation("activityAssignee")
  workTeamMembers            WorkTeamMember[]

  @@map("users")
}

// Company profile for report branding
model Profile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName String?
  tradingName String?
  logo        String?   // base64 or Supabase storage URL
  address     String?
  city        String?
  country     String?
  postcode    String?
  phone       String?
  website     String?
  abn         String?   // ABN / Company Reg / Tax ID
  registrationLabel String @default("ABN") // "ABN", "GST Reg", "UEN", "CRN" etc.

  // Report defaults
  defaultPreparedBy   String?
  defaultReportNotes  String?
  defaultCurrency     String  @default("SGD")
  defaultShowPricing  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// MTO MODULE — MtoSystem (was: System)
// ─────────────────────────────────────────────────────────────────────────────

model MtoSystem {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)

  name        String
  shortName   String?
  description String?
  icon        String   @default("📦")
  color       String   @default("#7917de")
  inputModel  String   @default("linear")
  isArchived  Boolean  @default(false)

  // All nested config stored as JSON
  materials      Json @default("[]")
  customDims     Json @default("[]")
  customCriteria Json @default("[]")
  variants       Json @default("[]")
  warnings       Json @default("[]")
  customBrackets Json @default("[]")
  workActivities Json @default("[]")

  isLocked         Boolean @default(false)
  materialSnapshot Json?

  mtoJobs     MtoJob[]
  reports     Report[]
  tenderItems TenderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("systems")
}

// ─────────────────────────────────────────────────────────────────────────────
// MTO MODULE — MtoJob (was: Job)
// ─────────────────────────────────────────────────────────────────────────────

model MtoJob {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User      @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)
  mtoSystemId String    @map("systemId")
  mtoSystem   MtoSystem @relation(fields: [mtoSystemId], references: [id], onDelete: Cascade)

  name        String
  notes       String?
  isArchived  Boolean @default(false)

  runs           Json    @default("[]")
  criteriaState  Json    @default("{}")
  variantState   Json    @default("{}")
  stockOptimMode String  @default("min_waste")
  calculatedAt   DateTime?
  matVersions    Json    @default("{}")
  lastResults    Json?

  reports     Report[]
  tenderItems TenderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([mtoSystemId])
  @@map("jobs")
}

// ─────────────────────────────────────────────────────────────────────────────
// RUN DRAFTS (auto-saved calculator state per user per system)
// ─────────────────────────────────────────────────────────────────────────────

model MtoRunDraft {
  id          String   @id @default(cuid())
  companyId   String
  userId      String
  mtoSystemId String

  runs           Json   @default("[]")
  stockOptimMode String @default("min_waste")

  updatedAt DateTime @updatedAt

  @@unique([userId, mtoSystemId])
  @@index([companyId])
  @@map("run_drafts")
}

// ─────────────────────────────────────────────────────────────────────────────
// MATERIAL SPECS (pricing + stock info — Pro only)
// ─────────────────────────────────────────────────────────────────────────────

model MaterialSpec {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User    @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)

  // Link to a material by product code (portable) or by material id (per-system)
  productCode   String?   // preferred — links across systems
  materialId    String?   // fallback — specific instance

  // Stock & logistics
  stockLength   Float?    // mm — standard stock/coil length
  storageLength Float?    // mm — max storage length on site
  weightPerM    Float?    // kg/m — for transport calculations
  supplier      String?
  leadTimeDays  Int?

  // Pricing
  unitPrice     Float?    // price per material unit (each, m, m², kg etc.)
  currency      String    @default("SGD")
  priceDate     DateTime? // when the price was last updated
  priceNotes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, productCode])
  @@index([companyId])
  @@map("material_specs")
}

// ─────────────────────────────────────────────────────────────────────────────
// REPORT
// ─────────────────────────────────────────────────────────────────────────────

model Report {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User    @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)
  mtoSystemId String? @map("systemId")
  mtoSystem   MtoSystem? @relation(fields: [mtoSystemId], references: [id], onDelete: SetNull)
  mtoJobId    String? @map("jobId")
  mtoJob      MtoJob?    @relation(fields: [mtoJobId], references: [id], onDelete: SetNull)

  // Module discriminator — which Exakt module generated this report
  module      String  @default("mto")  // 'mto' | 'tenders' | 'logistics' | 'finance' | 'people'

  // Report metadata
  title        String
  jobRef       String?
  preparedBy   String?
  preparedFor  String?
  reportDate   DateTime @default(now())
  revisionNo   String   @default("A")
  notes        String?
  isPublic     Boolean  @default(false)  // public share link
  publicToken  String?  @unique          // token for public URL

  // Branding snapshot (copied from Profile at report generation time)
  companyName  String?
  companyLogo  String?
  companyAddr  String?
  abn          String?

  // Report config
  showPricing  Boolean @default(false)
  showWeights  Boolean @default(false)
  currency     String  @default("SGD")

  // Calculation snapshot (denormalised for portability)
  systemName   String?
  inputModel   String?
  resultsSnapshot Json?
  specsSnapshot   Json?

  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([publicToken])
  @@map("reports")
}

// ─────────────────────────────────────────────────────────────────────────────
// CLIENTS
// ─────────────────────────────────────────────────────────────────────────────

model Client {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById   String
  createdBy     User     @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)

  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  notes         String?
  isArchived    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("clients")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENDERS MODULE
// ─────────────────────────────────────────────────────────────────────────────

model Tender {
  id             String        @id @default(cuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User          @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)

  name           String
  projectName    String?
  reference      String?       // RFQ / tender reference number
  submissionDate DateTime?
  status         TenderStatus  @default(DRAFT)
  notes          String?
  predefinedItems Json         @default("[]")  // { id, description, amount }[]
  isArchived     Boolean       @default(false)

  items     TenderItem[]
  reports   TenderReport[]
  projects  Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("tenders")
}

model TenderItem {
  id        String  @id @default(cuid())
  tenderId  String
  systemId  String?
  jobId     String?
  notes     String?
  sortOrder Int     @default(0)

  tender Tender     @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  system MtoSystem? @relation(fields: [systemId], references: [id], onDelete: SetNull)
  job    MtoJob?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([tenderId])
  @@map("tender_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// LIBRARY + GLOBAL TAGS
// ─────────────────────────────────────────────────────────────────────────────

model MaterialGrade {
  id           String        @id @default(cuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById  String
  createdBy    User          @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)

  name         String
  materialType String?
  standard     String?
  density      Float?        // g/cm³ — enables auto weight calculation
  notes        String?

  items        LibraryItem[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
  @@map("material_grades")
}

model Manufacturer {
  id         String        @id @default(cuid())
  companyId  String
  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User         @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)

  name          String
  contactPerson String?
  email         String?
  phone         String?
  country       String?
  website       String?
  notes         String?
  isArchived    Boolean       @default(false)

  items      LibraryItem[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
  @@map("manufacturers")
}

model LibraryItem {
  id             String         @id @default(cuid())
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User           @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)

  name           String
  unit           String         @default("each")
  notes          String?
  productCode    String?
  category       String         @default("other")
  photo          String?
  properties     Json           @default("{}")
  spec           Json?
  usedInSystems  String[]       @default([])

  gradeId        String?
  grade          MaterialGrade? @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  manufacturerId String?
  manufacturer   Manufacturer?  @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)

  certifications MaterialCertification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("library_items")
}

model MaterialCertification {
  id            String      @id @default(cuid())
  libraryItemId String
  libraryItem   LibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById   String
  createdBy     User        @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)

  type          String      // 'mill_cert' | 'ce' | 'iso' | 'test_report' | 'msds' | 'other'
  certNumber    String?
  issuedBy      String?
  issuedDate    DateTime?
  expiryDate    DateTime?
  fileUrl       String?
  fileName      String?
  notes         String?

  createdAt     DateTime @default(now())

  @@index([libraryItemId])
  @@index([companyId])
  @@map("material_certifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// LOGISTICS MODULE
// ─────────────────────────────────────────────────────────────────────────────

model Supplier {
  id            String  @id @default(cuid())
  companyId     String
  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById   String
  createdBy     User    @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)

  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  paymentTerms  String?
  notes         String?
  isArchived    Boolean @default(false)

  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("suppliers")
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  companyId    String
  company      Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById  String
  createdBy    User                @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)
  supplierId   String?
  supplier     Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  supplierName String?

  ref          String?
  status       PurchaseOrderStatus @default(DRAFT)
  orderDate    DateTime            @default(now())
  expectedDate DateTime?
  notes        String?

  lines          PurchaseOrderLine[]
  deliveryOrders DeliveryOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id            String        @id @default(cuid())
  poId          String
  po            PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  libraryItemId String?
  itemName      String
  itemUnit      String
  qtyOrdered    Float
  unitPrice     Float?
  notes         String?

  createdAt DateTime @default(now())

  @@map("po_lines")
}

model DeliveryOrder {
  id           String              @id @default(cuid())
  companyId    String
  company      Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById  String
  createdBy    User                @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)
  poId         String?
  po           PurchaseOrder?      @relation(fields: [poId], references: [id], onDelete: SetNull)

  ref           String?
  status        DeliveryOrderStatus @default(PENDING)
  expectedDate  DateTime?
  deliveredDate DateTime?
  notes         String?

  lines DeliveryOrderLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("delivery_orders")
}

model DeliveryOrderLine {
  id            String        @id @default(cuid())
  doId          String
  do            DeliveryOrder @relation(fields: [doId], references: [id], onDelete: Cascade)

  poLineId      String?
  libraryItemId String?
  itemName      String
  itemUnit      String
  qtyExpected   Float
  qtyDelivered  Float @default(0)

  createdAt DateTime @default(now())

  @@map("do_lines")
}

model MaterialCategory {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)

  name      String
  icon      String   @default("📦")
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())

  @@unique([companyId, name])
  @@index([companyId])
  @@map("material_categories")
}

model GlobalTag {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User    @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)

  name  String
  color String @default("#7c3aed")
  order Int    @default(0)

  createdAt DateTime @default(now())

  @@index([companyId])
  @@map("global_tags")
}

// ─────────────────────────────────────────────────────────────────────────────
// GLOBAL ACTIVITY LIBRARY
// ─────────────────────────────────────────────────────────────────────────────

model ActivityLibraryItem {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User    @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)

  name        String
  phase       String    // 'fabrication' | 'installation' | 'commissioning' | 'transport' | 'third_party'
  icon        String?
  description String?

  rateType       String    // ActivityRateType
  defaultTimeMin Float?    // default time in minutes per unit
  speedMode      String?   // 'time_per_unit' | 'rate'
  defaultRate    Float?    // units per hour (rate mode)

  workActivityRateId String?

  supplier        String?
  supplierContact String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("activity_library_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// LABOUR RATES
// ─────────────────────────────────────────────────────────────────────────────

model LabourRate {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User    @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)

  name        String                 // "Cable swaging", "Powder coat", "Fabricator"
  category    String   @default("")  // grouping: "Fabrication", "Installation", "Finishing"
  unitType    String                 // 'per_piece' | 'per_dim' | 'per_hour' | 'lump_sum'
  unitLabel   String   @default("")  // display: "pc", "m", "m²", "hr", "lot"
  rate        Float                  // price per unit (in company's defaultCurrency)
  notes       String?
  isArchived  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workActivityRates WorkActivityRate[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("labour_rates")
}

// ─────────────────────────────────────────────────────────────────────────────
// Work Categories & Activity Rates
// ─────────────────────────────────────────────────────────────────────────────

model WorkCategory {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User    @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)

  name        String
  icon        String   @default("🔧")
  color       String   @default("#7c3aed")
  description String?
  sortOrder   Int      @default(0)
  isArchived  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workActivityRates WorkActivityRate[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("work_categories")
}

model WorkActivityRate {
  id             String  @id @default(cuid())
  companyId      String
  company        Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User    @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)

  name           String
  workCategoryId String
  workCategory   WorkCategory @relation(fields: [workCategoryId], references: [id])
  labourRateId   String
  labourRate     LabourRate   @relation(fields: [labourRateId], references: [id])

  // Snapshots
  categoryName   String   @default("")
  categoryIcon   String   @default("🔧")
  rateName       String   @default("")
  rateValue      Float    @default(0)
  rateUnitType   String   @default("per_hour")
  rateUnitLabel  String   @default("hr")

  // Default speed
  speedMode          String?    // 'time_per_unit' | 'rate'
  defaultTimePerUnit Float?
  defaultRatePerHr   Float?
  crewSize           Int      @default(1)

  notes       String?
  isArchived  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
  @@index([workCategoryId])
  @@index([labourRateId])
  @@map("work_activity_rates")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENDER REPORTS (quotation builder)
// ─────────────────────────────────────────────────────────────────────────────

model TenderReport {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("createdByUser", fields: [createdById], references: [id], onDelete: Cascade)
  tenderId    String
  tender      Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  // Header
  title             String   @default("Quotation")
  reference         String?
  date              DateTime @default(now())
  validUntil        DateTime?
  preparedBy        String?
  revisionNo        String   @default("0")
  status            String   @default("draft")

  // Branding snapshots
  companyName       String?
  companyLogo       String?
  companyAddr       String?
  registrationNo    String?
  registrationLabel String?
  accentColor       String?

  // Client snapshot
  clientName        String?
  clientContact     String?
  clientEmail       String?
  clientAddr        String?

  // Content (JSON array of TenderReportSection)
  sections          Json     @default("[]")

  // Margins
  overallMarginPct  Float    @default(0)

  // Footer
  paymentTerms      String?
  validityPeriod    String?
  disclaimer        String?
  notes             String?
  internalNotes     String?

  // Config
  currency          String   @default("SGD")
  showAppendix      Boolean  @default(false)

  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
  @@index([tenderId])
  @@map("tender_reports")
}

// ─────────────────────────────────────────────────────────────────────────────
// TASKS
// ─────────────────────────────────────────────────────────────────────────────

model Task {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("taskCreatedBy", fields: [createdById], references: [id])
  assigneeId  String
  assignee    User     @relation("taskAssignee", fields: [assigneeId], references: [id])

  title       String
  description String?
  priority    String   @default("medium")
  status      String   @default("open")

  startDate   DateTime?
  targetDate  DateTime?

  linkedUrl   String?
  linkedType  String?
  linkedLabel String?

  checklist   Json     @default("[]")
  output      Json     @default("[]")
  ccUserIds   String[] @default([])

  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  comments    TaskComment[]

  @@index([companyId])
  @@index([assigneeId])
  @@index([createdById])
  @@map("tasks")
}

model TaskComment {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation("taskComments", fields: [userId], references: [id])

  content     String
  attachments Json     @default("[]")

  createdAt   DateTime @default(now())

  @@index([taskId])
  @@map("task_comments")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("notifications", fields: [userId], references: [id])

  type      String
  title     String
  body      String?
  taskId    String?
  isRead    Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([companyId])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECTS MODULE
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id             String        @id @default(cuid())
  companyId      String
  createdById    String
  tenderId       String?
  reportId       String?
  quotationNo    String?
  name           String
  address        String?
  longitude      Float?
  latitude       Float?
  managerId      String?
  managerName    String?
  startDate      DateTime?
  endDate        DateTime?
  clientName     String?
  contractValue  Float         @default(0)
  status         ProjectStatus @default(PLANNING)
  systemIds      String[]      @default([])
  isArchived     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy  User             @relation("projectCreatedBy", fields: [createdById], references: [id])
  manager    User?            @relation("projectManager", fields: [managerId], references: [id])
  tender     Tender?          @relation(fields: [tenderId], references: [id])
  milestones ProjectMilestone[]

  @@index([companyId])
  @@index([tenderId])
  @@map("projects")
}

model ProjectMilestone {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  color       String   @default("#3b82f6")
  startDate   DateTime?
  endDate     DateTime?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project    Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activities ProjectActivity[]

  @@index([projectId])
  @@map("project_milestones")
}

model ProjectActivity {
  id             String         @id @default(cuid())
  milestoneId    String
  name           String
  description    String?
  assigneeId     String?
  assigneeName   String?
  teamId         String?
  requiredOutput String[]       @default([])
  skills         String[]       @default([])
  estimatedHours Float?
  startDate      DateTime?
  endDate        DateTime?
  isWithinDay    Boolean        @default(false)
  startTime      String?
  endTime        String?
  status         ActivityStatus @default(NOT_STARTED)
  progress       Int            @default(0)
  color          String         @default("#10b981")
  sortOrder      Int            @default(0)
  assetIds       String[]       @default([])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  milestone  ProjectMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  assignee   User?            @relation("activityAssignee", fields: [assigneeId], references: [id])
  team       WorkTeam?        @relation(fields: [teamId], references: [id])

  @@index([milestoneId])
  @@index([teamId])
  @@index([assigneeId])
  @@map("project_activities")
}

model WorkTeam {
  id        String   @id @default(cuid())
  companyId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members    WorkTeamMember[]
  activities ProjectActivity[]

  @@index([companyId])
  @@map("work_teams")
}

model WorkTeamMember {
  id        String  @id @default(cuid())
  teamId    String
  userId    String?
  name      String?
  avatarUrl String?
  skills    String[] @default([])

  team WorkTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User?    @relation(fields: [userId], references: [id])

  @@index([teamId])
  @@index([userId])
  @@map("work_team_members")
}

model ProjectAsset {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  category    String?
  description String?
  location    String?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("project_assets")
}
